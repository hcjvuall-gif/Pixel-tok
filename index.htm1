<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PixelTok</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:black;
overflow:hidden;
font-family:Arial;
}

.feed{
height:100vh;
overflow-y:scroll;
scroll-snap-type:y mandatory;
}

.video-container{
height:100vh;
position:relative;
scroll-snap-align:start;
}

video{
width:100%;
height:100%;
object-fit:cover;
}

.info{
position:absolute;
bottom:30px;
left:20px;
color:white;
}

.actions{
position:absolute;
right:20px;
bottom:100px;
color:white;
font-size:30px;
text-align:center;
}

.actions div{
margin:20px 0;
cursor:pointer;
}
</style>

</head>
<body>

<div class="feed">

<div class="video-container">
<video autoplay muted loop>
<source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
</video>

<div class="info">
<h3>@pixeltok</h3>
<p>أول فيديو</p>
</div>

<div class="actions">
<div>❤️</div>
<div>💬</div>
<div>🔄</div>
</div>
</div>

<div class="video-container">
<video autoplay muted loop>
<source src="https://www.w3schools.com/html/movie.mp4" type="video/mp4">
</video>

<div class="info">
<h3>@user2</h3>
<p>فيديو ثاني</p>
</div>

<div class="actions">
<div>❤️</div>
<div>💬</div>
<div>🔄</div>
</div>
</div>

</div>

</body>
</html>
